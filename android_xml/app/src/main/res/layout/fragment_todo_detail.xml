<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView android:id="@+id/detailTitle"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="22sp" android:layout_marginBottom="8dp" />

    <TextView android:id="@+id/detailDescription"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="14sp" android:layout_marginBottom="8dp" />

    <TextView android:id="@+id/detailPriority"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="12sp" android:layout_marginBottom="4dp" />

    <TextView android:id="@+id/detailStatus"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textSize="12sp" />

</LinearLayout>
